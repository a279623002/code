{
  "openapi": "3.0.0",
  "info": {
    "title": "Order Service API",
    "description": "go-zero 订单管理微服务 API 文档",
    "version": "1.0.0",
    "contact": {
      "name": "go-zero-order"
    }
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8888",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "order",
      "description": "订单管理"
    }
  ],
  "paths": {
    "/api/order": {
      "post": {
        "tags": ["order"],
        "summary": "创建订单",
        "operationId": "createOrder",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderReq"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateOrderResp"
                }
              }
            }
          }
        }
      }
    },
    "/api/order/list": {
      "get": {
        "tags": ["order"],
        "summary": "订单列表",
        "operationId": "listOrder",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListOrderResp"
                }
              }
            }
          }
        }
      }
    },
    "/api/order/{id}": {
      "get": {
        "tags": ["order"],
        "summary": "查询订单详情",
        "operationId": "getOrder",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetOrderResp"
                }
              }
            }
          }
        }
      }
    },
    "/api/order/{id}/status": {
      "put": {
        "tags": ["order"],
        "summary": "更新订单状态",
        "operationId": "updateOrderStatus",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateOrderStatusReq"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateOrderStatusResp"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "order_no": {
            "type": "string"
          },
          "user_id": {
            "type": "integer",
            "format": "int64"
          },
          "total_amount": {
            "type": "number",
            "format": "double"
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "description": "1-待支付 2-已支付 3-已发货 4-已完成 5-已取消"
          },
          "remark": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          }
        }
      },
      "CreateOrderReq": {
        "type": "object",
        "required": ["user_id", "total_amount"],
        "properties": {
          "user_id": {
            "type": "integer",
            "format": "int64"
          },
          "total_amount": {
            "type": "number",
            "format": "double"
          },
          "remark": {
            "type": "string"
          }
        }
      },
      "CreateOrderResp": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "order_no": {
            "type": "string"
          }
        }
      },
      "GetOrderResp": {
        "type": "object",
        "properties": {
          "order": {
            "$ref": "#/components/schemas/Order"
          }
        }
      },
      "ListOrderResp": {
        "type": "object",
        "properties": {
          "list": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Order"
            }
          },
          "total": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "UpdateOrderStatusReq": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "integer",
            "format": "int32",
            "description": "1-待支付 2-已支付 3-已发货 4-已完成 5-已取消"
          }
        }
      },
      "UpdateOrderStatusResp": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
